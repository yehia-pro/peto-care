    "@stripe/stripe-js": "^8.5.3",
    "@supabase/supabase-js": "^2.57.4",
    "antd": "^5.29.1",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "firebase": "^12.6.0",
    "i18next": "^25.6.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.263.1",
