    "react": "^18.3.1",
    "react-big-calendar": "^1.19.4",
    "react-datepicker": "^8.9.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.3.5",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.8.1",
    "recharts": "^3.5.1",
