{
  "name": "veterinary-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:cf": "tsc && vite build && node scripts/fix-html.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start:all": "start-all.bat",
    "open_site": "open_site.cmd",
    "start_site": "start_site.cmd",
    "organize": "node scripts/organize.js --lang=ar",
    "organize:dry": "node scripts/organize.js --lang=ar --dry-run",
    "organize:move": "node scripts/organize.js --lang=ar --move",
    "server:dev": "npm run --prefix server dev",
    "server:build": "npm run --prefix server build",
    "server:start": "npm run --prefix server start"
  },
  "dependencies": {
